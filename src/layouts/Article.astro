---
import Base from './Base.astro';
export interface Props { title: string; summary: string; date: Date; tags: string[]; }
const { title, summary, date, tags } = Astro.props;
const dateStr = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Article', headline: title, description: summary,
  datePublished: date.toISOString(), author: { '@type': 'Organization', name: 'The Pulse Paper' },
  publisher: { '@type': 'Organization', name: 'The Pulse Paper' },
};
---
<Base title={`${title} | The Pulse Paper`} description={summary} type="article" publishedDate={date}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="wrap-narrow art">
    <div class="mono art-meta">{dateStr}{tags.length ? ` · ${tags.join(' · ')}` : ''}</div>
    <h1>{title}</h1>
    <p class="art-lede">{summary}</p>
    <div class="art-rule"></div>
    <div class="art-body"><slot /></div>
    <div class="art-cta">
      <p>This is a free article. The full weekly brief — ten sections, every Sunday — is The Pulse Paper.</p>
      <a href="/#subscribe" class="art-btn">Subscribe — it&rsquo;s free</a>
    </div>
  </article>
  <style>
    .art { padding-top: 56px; }
    .art-meta { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; font-weight: 500; }
    .art h1 { font-family: var(--font-serif); font-size: 38px; line-height: 1.15; margin-bottom: 16px; letter-spacing: -0.5px; }
    .art-lede { font-size: 19px; line-height: 1.6; color: var(--muted); margin-bottom: 24px; }
    .art-rule { height: 2px; background: var(--ink); margin-bottom: 28px; }
    .art-body { font-size: 17px; }
    .art-body :global(p) { margin-bottom: 18px; }
    .art-body :global(h2) { font-family: var(--font-serif); font-size: 24px; margin: 32px 0 12px; }
    .art-body :global(blockquote) { border-left: 3px solid var(--accent); margin: 22px 0; padding: 4px 0 4px 18px; color: var(--muted); font-style: italic; }
    .art-cta { margin-top: 44px; padding: 28px; background: var(--card-bg); border: 1px solid var(--border); border-top: 3px solid var(--accent); text-align: center; }
    .art-cta p { font-size: 14px; color: var(--muted); margin-bottom: 16px; }
    .art-btn { display: inline-block; background: var(--accent); color: #fff; font-weight: 600; padding: 12px 28px; border-radius: 2px; font-size: 14px; }
    .art-btn:hover { background: var(--accent-dark); }
  </style>
</Base>
