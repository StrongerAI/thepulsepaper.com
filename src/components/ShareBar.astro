<script>
(function () {
  var bar  = document.getElementById('sf-bar');
  var wa   = document.getElementById('sf-wa');
  var li   = document.getElementById('sf-li');
  var x    = document.getElementById('sf-x');
  var em   = document.getElementById('sf-em');
  var copy = document.getElementById('sf-copy');
  if (!bar) return;

  var url   = window.location.href;
  var title = document.title;
  var enc   = encodeURIComponent;

  if (wa) wa.href = 'https://wa.me/?text=' + enc(title + ' ' + url);
  if (li) li.href = 'https://www.linkedin.com/sharing/share-offsite/?url=' + enc(url);
  if (x)  x.href  = 'https://x.com/intent/tweet?url=' + enc(url) + '&text=' + enc(title);
  if (em) em.href = 'mailto:?subject=' + enc(title) + '&body=' + enc(url);

  if (copy) {
    copy.addEventListener('click', function () {
      navigator.clipboard.writeText(url).then(function () {
        var icon = document.getElementById('sf-copy-icon');
        if (icon) icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
        setTimeout(function () {
          if (icon) icon.innerHTML = '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>';
        }, 2000);
      });
    });
  }

  window.addEventListener('scroll', function () {
    if (window.scrollY > 320) {
      bar.classList.add('sf-show');
    } else {
      bar.classList.remove('sf-show');
    }
  }, { passive: true });
})();
</script>

<style>
  .sf-bar {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%) translateX(100%);
    z-index: 90;
    display: flex;
    flex-direction: column;
    gap: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease, transform 0.28s ease;
  }
  .sf-bar.sf-show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }
  .sf-btn {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-right: none;
    color: var(--muted);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    box-shadow: -2px 2px 8px rgba(0,0,0,0.07);
  }
  .sf-btn + .sf-btn { border-top: none; }
  .sf-btn:first-child { border-radius: 4px 0 0 0; }
  .sf-btn:last-child  { border-radius: 0 0 0 4px; }
  .sf-btn:hover { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  .sf-btn svg { flex-shrink: 0; pointer-events: none; }

  @media (max-width: 640px) {
    .sf-bar {
      top: auto;
      bottom: 20px;
      right: 0;
      transform: translateX(100%);
      flex-direction: row;
    }
    .sf-bar.sf-show { transform: translateX(0); }
    .sf-btn { border: 1px solid var(--border); border-right: none; }
    .sf-btn + .sf-btn { border-left: none; border-right: none; }
    .sf-btn:first-child { border-radius: 4px 0 0 4px; border-right: none; }
    .sf-btn:last-child  { border-radius: 0 4px 4px 0; border-right: none; }
  }
</style>
