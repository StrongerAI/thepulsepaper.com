---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { editionsList } from '../data/editions.js';

const editions = editionsList.slice(0, 3);
const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

// Section spine shown in the "what's inside" grid.
const sections = [
  'PKR & Macro', 'Oil & Energy', 'Economic Watchout', 'Commodities', 'Logistics & Ports',
  'Regulatory', 'Weather & Agri', 'Political Risk', 'Global Signals', 'Action Items',
];

// "Glimpse inside" — illustrative format cards, styled exactly like edition data cards.
const sample = [
  { label: 'Brent Crude', value: 'Oil benchmark', delta: 'USD/bbl · WoW direction', tone: 'red' },
  { label: 'USD / PKR', value: 'Exchange rate', delta: 'weekly close · trend', tone: 'amber' },
  { label: 'KSE-100', value: 'Equity market', delta: 'index pts · WoW %', tone: 'green' },
  { label: 'FBR Revenue', value: 'Fiscal pulse', delta: 'Rs bn · vs target', tone: 'red' },
];

// Who it reads for — broadened beyond supply chain to the full decision-maker audience.
const audience = [
  'CFOs & Finance', 'Investors & Analysts', 'Business Owners', 'Treasury & Risk',
  'Supply Chain & Procurement', 'Country Managers', 'Operations Leaders', 'Policy & Advisory',
];
---
<Base
  title="The Pulse Paper — Independent economic intelligence for Pakistan"
  description="Independent analysis of Pakistan's economy and markets — what moved last week, what's developing now, and what to do. One brief, every Sunday, for the people who make decisions with money."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-tag">The Pulse Paper &middot; Economic Intelligence &middot; Pakistan</div>
      {editions.length > 0 ? (
        <div class="hero-edition">
          <div class="hero-ed-kicker mono">Latest &middot; Edition No. {editions[0].no} &middot; {editions[0].date}</div>
          <a class="hero-ed-title" href={`/editions/${editions[0].slug}.html`}>{editions[0].title}</a>
          <p class="hero-ed-sum">{editions[0].summary}</p>
          <a class="hero-ed-read" href={`/editions/${editions[0].slug}.html`}>Read this edition &rarr;</a>
        </div>
      ) : (
        <h1>Independent economic intelligence for Pakistan</h1>
      )}
    </div>
  </section>

  <!-- LATEST EDITIONS + SIGNALS -->
  <section class="wrap home-grid">
    <div class="col">
      <div class="col-head"><h2>Latest editions</h2><a href="/editions" class="more">All editions →</a></div>
      {editions.map((e) => (
        <a class="mini" href={`/editions/${e.slug}.html`}>
          <span class="mono mini-num">No. {e.no} · {e.date}</span>
          <span class="mini-title">{e.title}</span>
        </a>
      ))}
      {editions.length === 0 && <p class="muted">First edition coming soon.</p>}
    </div>
    <div class="col">
      <div class="col-head"><h2>Signals</h2><a href="/signals" class="more">All signals →</a></div>
      {articles.map((a) => (
        <a class="mini" href={`/signals/${a.slug}`}>
          <span class="mono mini-num">{a.data.date.toLocaleDateString('en-GB', { day:'numeric', month:'short' })}</span>
          <span class="mini-title">{a.data.title}</span>
        </a>
      ))}
      {articles.length === 0 && <p class="muted">First article coming soon.</p>}
    </div>
  </section>

  <!-- SPECIALS CALLOUT -->
  <section class="wrap specials-callout">
    <div class="sc-inner">
      <div class="sc-label">Special Edition</div>
      <div class="sc-body">
        <div class="sc-tag mono">FY27 Budget Special &middot; 14 June 2026</div>
        <a class="sc-title" href="/specials/pulse-fy27-budget-special.html">The borrowed balance</a>
        <p class="sc-sum muted">The stabilisation is real, the growth is assumed, and the balance is borrowed. Pakistan's FY27 budget: the deficit bridge, the provincial dependence, and six things to watch.</p>
      </div>
      <a class="sc-cta" href="/specials/pulse-fy27-budget-special.html">Read →</a>
    </div>
  </section>

  <!-- GLIMPSE INSIDE -->
  <section class="block-cream">
    <div class="wrap">
      <div class="block-head">
        <h2>What every edition tracks</h2>
        <p class="muted">Each Sunday brief covers these indicators &mdash; with the week&rsquo;s actual figures, context, and what they mean for Pakistan.</p>
      </div>
      <div class="sample-grid">
        {sample.map((s) => (
          <div class={`data-card ${s.tone}`}>
            <div class="data-label">{s.label}</div>
            <div class="data-value">{s.value}</div>
            <div class="data-delta delta-flat">{s.delta}</div>
          </div>
        ))}
      </div>
      <div style="margin-top: 24px;">
        <a href="/editions" class="more">Read a full edition →</a>
      </div>
    </div>
  </section>

  <!-- THREE PILLARS -->
  <section class="wrap block">
    <div class="block-head">
      <h2>The intelligence gap, closed</h2>
      <p class="muted">The forces moving Pakistan&rsquo;s economy are scattered across dozens of sources. The Pulse Paper brings them into one focused brief, every week — structured around three questions.</p>
    </div>
    <div class="pillars">
      <div class="pillar">
        <h3>What Moved</h3>
        <p>PKR, oil benchmarks, fuel prices, commodities, KSE-100, inflation, ports — the numbers that changed last week, and what they mean for your costs and decisions.</p>
      </div>
      <div class="pillar">
        <h3>What&rsquo;s Developing</h3>
        <p>Geopolitical risk, regulatory shifts, weather, diplomatic signals, disruption threats — the forces building now that will land on your business next.</p>
      </div>
      <div class="pillar">
        <h3>What To Do</h3>
        <p>Prioritised action items with specific dates, thresholds, and recommendations. Not &ldquo;monitor the situation&rdquo; — real decisions with deadlines.</p>
      </div>
    </div>
  </section>

  <!-- TEN SECTIONS -->
  <section class="wrap block">
    <div class="block-head">
      <h2>Ten sections. One read.</h2>
      <p class="muted">Every edition covers the full landscape — from macro and markets to logistics and political risk.</p>
    </div>
    <div class="sections-grid">
      {sections.map((s, i) => (
        <div class="section-chip"><span class="chip-num mono">{String(i + 1).padStart(2, '0')}</span>{s}</div>
      ))}
    </div>
  </section>

  <!-- WHO IT'S FOR + social proof -->
  <section class="block-paper">
    <div class="wrap">
      <div class="block-head center">
        <h2>Built for the people who make decisions with money</h2>
        <p class="muted">Read across Pakistan by the people who act on what moves.</p>
      </div>
      <div class="audience">
        {audience.map((a) => <span class="aud-tag">{a}</span>)}
      </div>
      <!-- Replace this line with a real, attributed quote once you have one cleared for use. -->
      <p class="proofline">Read each week by analysts, CFOs, investors, and business owners across Pakistan.</p>
    </div>
  </section>

  <!-- RHYTHM -->
  <section class="wrap block">
    <div class="block-head">
      <h2>What arrives, and when</h2>
      <p class="muted">Three publication types. A predictable schedule. Everything a decision-maker needs to stay ahead of Pakistan&rsquo;s economy.</p>
    </div>
    <div class="rhythm">
      <div class="rhythm-card rhythm-weekly">
        <div class="rhythm-name">The Weekly Brief</div>
        <div class="rhythm-when mono">Every Sunday evening</div>
        <ul class="rhythm-list">
          <li>PKR, oil benchmarks, commodities &amp; KSE-100</li>
          <li>Data cards, charts &amp; commodity tables</li>
          <li>Disruption calendar &amp; scenario analysis</li>
          <li>Prioritised action items with deadlines</li>
        </ul>
      </div>
      <div class="rhythm-card rhythm-monthly">
        <div class="rhythm-name">The Monthly Digest</div>
        <div class="rhythm-when mono">Last Sunday of the month</div>
        <ul class="rhythm-list">
          <li>30-day trend analysis across all ten sections</li>
          <li>Macro risk scorecard with directional ratings</li>
          <li>Longer-horizon outlook &amp; scenario map</li>
          <li>Strategic recommendations for the month ahead</li>
        </ul>
      </div>
      <div class="rhythm-card rhythm-special">
        <div class="rhythm-name">Special Editions</div>
        <div class="rhythm-when mono">Event-driven &middot; As they happen</div>
        <ul class="rhythm-list">
          <li>Budget analysis &amp; fiscal deep dives</li>
          <li>Policy shifts &amp; regulatory events</li>
          <li>Geopolitical &amp; supply chain shocks</li>
          <li>One-off briefs when the story demands it</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="wrap-narrow center">
      <h2>Start every week informed</h2>
      <p class="muted">Join the readers who walk into Monday already knowing what moved.</p>
      <a href="#subscribe" class="cta-btn">Subscribe — it&rsquo;s free</a>
    </div>
  </section>

  <!-- Offscreen MailerLite form — initialised by their JS, driven by the hero form above -->
  <div class="ml-sink" aria-hidden="true">
    <div class="ml-embedded" data-form="taVtu7"></div>
  </div>

  <style>
    /* page-level background override — white instead of cream */
    :global(body) { background: #fafaf8; }

    /* HERO */
    .hero { background: var(--ink); color: var(--paper); padding: 80px 0 64px; position: relative; overflow: hidden; }
    .hero::before {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background-image: radial-gradient(rgba(255,255,255,0.10) 1.2px, transparent 1.2px);
      background-size: 60px 60px;
    }
    .hero-inner { max-width: var(--maxw-wide); margin: 0 auto; padding: 0 40px; position: relative; z-index: 1; }
    .hero-tag { font-size: 10px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(245,241,235,0.35); margin-bottom: 28px; }

    /* featured edition */
    .hero-ed-kicker { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(245,241,235,0.4); margin-bottom: 14px; }
    .hero-ed-title { display: block; font-family: var(--font-serif); font-size: 52px; font-weight: 400; line-height: 1.15; letter-spacing: -0.5px; color: var(--paper); text-decoration: none; max-width: 920px; margin-bottom: 20px; transition: color 0.2s; }
    .hero-ed-title:hover { color: rgba(245,241,235,0.75); }
    .hero-ed-sum { font-size: 16px; line-height: 1.7; color: rgba(245,241,235,0.5); max-width: 760px; margin-bottom: 22px; }
    .hero-ed-read { font-size: 13px; font-weight: 600; color: var(--accent); letter-spacing: 0.3px; }
    .hero-ed-read:hover { color: var(--accent-dark); }

    /* fallback h1 when no editions */
    .hero h1 { font-family: var(--font-serif); font-size: 46px; font-weight: 400; line-height: 1.1; margin-bottom: 24px; letter-spacing: -0.5px; }

    /* subscribe area */
    .hero-divider { width: 40px; height: 1px; background: rgba(245,241,235,0.12); margin: 32px 0; }
    .hero-prompt { font-size: 13px; color: rgba(245,241,235,0.4); margin-bottom: 14px; font-weight: 500; letter-spacing: 0.2px; }
    .hero-note { margin-top: 12px; font-size: 11px; color: rgba(245,241,235,0.25); font-weight: 500; }

    /* shared block scaffolding */
    .block { padding: 64px 40px; }
    .block-head { max-width: 640px; margin-bottom: 36px; }
    .block-head.center { margin-left: auto; margin-right: auto; text-align: center; }
    .block-head h2 { font-family: var(--font-serif); font-size: 30px; font-weight: 400; margin-bottom: 12px; letter-spacing: -0.5px; }
    .block-head p { font-size: 16px; }
    .center { text-align: center; }

    /* three pillars */
    .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .pillar { background: var(--card-bg); border: 1px solid var(--border); border-top: 3px solid var(--accent); padding: 24px; }
    .pillar h3 { font-family: var(--font-sans); font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 10px; }
    .pillar p { font-size: 14.5px; line-height: 1.6; }

    /* glimpse inside */
    .block-cream { background: var(--paper); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 64px 0; }
    .sample-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    .sample-grid .data-value { font-size: 17px; font-weight: 600; letter-spacing: -0.2px; }

    /* ten sections */
    .sections-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
    .section-chip { background: var(--card-bg); border: 1px solid var(--border); padding: 14px 12px; font-size: 13px; font-weight: 500; display: flex; flex-direction: column; gap: 6px; }
    .chip-num { font-size: 11px; color: var(--accent); font-weight: 600; }

    /* who it's for */
    .block-paper { background: #fff; padding: 64px 40px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .audience { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; max-width: 760px; margin: 0 auto; }
    .aud-tag { background: var(--card-bg); border: 1px solid var(--border); padding: 9px 16px; font-size: 13.5px; font-weight: 500; border-radius: 2px; }
    .proofline { text-align: center; font-family: var(--font-serif); font-style: italic; font-size: 18px; color: var(--muted); margin-top: 32px; }

    /* rhythm */
    .rhythm { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .rhythm-card { border: 1px solid var(--border); background: var(--card-bg); padding: 22px 24px; display: flex; flex-direction: column; gap: 10px; }
    .rhythm-weekly  { border-top: 3px solid var(--gold); }
    .rhythm-monthly { border-top: 3px solid var(--muted); }
    .rhythm-special { border-top: 3px solid var(--accent); }
    .rhythm-name { font-family: var(--font-serif); font-size: 18px; font-weight: 400; line-height: 1.2; }
    .rhythm-when { font-size: 10px; letter-spacing: 1px; color: var(--muted); text-transform: uppercase; font-weight: 600; }
    .rhythm-list { list-style: none; margin: 4px 0 0; display: flex; flex-direction: column; gap: 8px; border-top: 1px solid var(--border); padding-top: 12px; }
    .rhythm-list li { font-size: 13.5px; line-height: 1.5; color: var(--ink); }

    /* latest grid */
    .home-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; padding-top: 56px; padding-bottom: 8px; }
    .col-head { display: flex; justify-content: space-between; align-items: baseline; border-bottom: 2px solid var(--ink); padding-bottom: 10px; margin-bottom: 8px; }
    .col-head h2 { font-family: var(--font-serif); font-size: 20px; margin: 0; }
    .more { font-size: 13px; color: var(--accent); font-weight: 600; }
    .mini { display: flex; flex-direction: column; gap: 3px; padding: 14px 0; border-bottom: 1px solid var(--border); }
    .mini:last-child { border-bottom: none; }
    .mini-num { font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); font-weight: 600; }
    .mini-title { font-family: var(--font-serif); font-size: 17px; line-height: 1.3; }
    .mini:hover .mini-title { color: var(--accent); }

    /* specials callout */
    .specials-callout { padding: 32px 40px; }
    .sc-inner {
      display: flex; align-items: center; gap: 24px;
      border: 1px solid var(--border); border-left: 3px solid var(--accent);
      background: var(--card-bg); padding: 20px 24px;
    }
    .sc-label {
      font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      color: var(--accent); writing-mode: vertical-rl; transform: rotate(180deg);
      white-space: nowrap; flex-shrink: 0;
    }
    .sc-body { flex: 1; }
    .sc-tag { font-size: 11px; letter-spacing: 0.5px; color: var(--muted); text-transform: uppercase; margin-bottom: 6px; font-weight: 600; }
    .sc-title { font-family: var(--font-serif); font-size: 20px; line-height: 1.25; display: block; margin-bottom: 6px; }
    .sc-title:hover { color: var(--accent); }
    .sc-sum { font-size: 13.5px; line-height: 1.6; }
    .sc-cta { flex-shrink: 0; font-size: 13px; font-weight: 600; color: var(--accent); white-space: nowrap; }
    @media (max-width: 768px) {
      .specials-callout { padding: 20px; }
      .sc-inner { flex-direction: column; align-items: flex-start; gap: 12px; }
      .sc-label { writing-mode: horizontal-tb; transform: none; }
    }

    .hero-form { display: flex; gap: 10px; max-width: 480px; }
    .hero-form input { flex: 1; padding: 14px 18px; border: 1px solid rgba(245,241,235,0.15); background: rgba(245,241,235,0.06); color: var(--paper); font-family: var(--font-sans); font-size: 14px; border-radius: 2px; outline: none; }
    .hero-form input::placeholder { color: rgba(245,241,235,0.3); }
    .hero-form input:focus { border-color: var(--accent); }
    .hero-form button { background: var(--accent); color: #fff; border: none; padding: 14px 28px; font-family: var(--font-sans); font-size: 14px; font-weight: 600; border-radius: 2px; cursor: pointer; white-space: nowrap; }
    .hero-form button:hover { background: var(--accent-dark); }
    .hero-success { font-size: 14px; color: rgba(245,241,235,0.8); max-width: 480px; padding: 14px 0 4px; }
    .ml-sink { position: fixed; left: -9999px; top: -9999px; width: 1px; height: 1px; overflow: hidden; pointer-events: none; }

    /* final cta */
    .final-cta { padding: 72px 40px 24px; }
    .final-cta h2 { font-family: var(--font-serif); font-size: 30px; font-weight: 400; margin-bottom: 12px; }
    .cta-btn { display: inline-block; background: var(--accent); color: #fff; font-weight: 600; padding: 13px 30px; border-radius: 2px; font-size: 15px; margin-top: 20px; }
    .cta-btn:hover { background: var(--accent-dark); }

    @media (max-width: 768px) {
      .hero { padding: 72px 0 48px; }
      .hero-inner { padding: 0 20px; }
      .hero-ed-title { font-size: 32px; letter-spacing: -0.3px; }
      .hero-ed-sum { font-size: 15px; }
      .hero h1 { font-size: 30px; }
      .hero-form { flex-direction: column; max-width: 100%; }
      .block, .block-paper, .block-cream, .final-cta { padding-left: 20px; padding-right: 20px; }
      .pillars { grid-template-columns: 1fr; }
      .sample-grid { grid-template-columns: 1fr 1fr; }
      .sections-grid { grid-template-columns: 1fr 1fr; }
      .rhythm { grid-template-columns: 1fr; gap: 12px; }
      .home-grid { grid-template-columns: 1fr; gap: 36px; }
    }
  </style>

  <script>
    (function () {
      var form = document.getElementById('heroSubscribeForm') || document.getElementById('subscribe');
      if (!form || form.tagName !== 'FORM') return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var emailVal = (document.getElementById('heroEmail') || form.querySelector('input[type="email"]')).value.trim();
        if (!emailVal) return;
        var mlInput = document.querySelector('.ml-sink input[type="email"]');
        var mlBtn = document.querySelector('.ml-sink button[type="submit"], .ml-sink .primary');
        if (mlInput && mlBtn) {
          mlInput.value = emailVal;
          mlInput.dispatchEvent(new Event('input', { bubbles: true }));
          mlInput.dispatchEvent(new Event('change', { bubbles: true }));
          setTimeout(function () { mlBtn.click(); }, 60);
        }
        form.style.display = 'none';
        var note = document.getElementById('heroNote');
        if (note) {
          note.textContent = "You’re in. First edition lands Sunday.";
          note.style.color = 'rgba(245,241,235,0.75)';
          note.style.fontSize = '15px';
        }
      });
    })();
  </script>
</Base>
