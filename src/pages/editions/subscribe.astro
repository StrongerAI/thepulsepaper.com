---
import Base from '../layouts/Base.astro';
---
<Base
  title="Subscribe | The Pulse Paper"
  description="Subscribe to The Pulse Paper: independent weekly economic intelligence for Pakistan. Free."
>
  <section class="wrap sub">
    <header class="sub-head">
      <h1>Subscribe to The Pulse</h1>
      <p class="tagline">The Week Ahead: what decision-makers need to know before Monday</p>
      <p class="muted">Independent weekly economic intelligence for Pakistan. Markets, the budget, oil, commodities, and the signals that move them. Free to your inbox, every week.</p>
    </header>
    <div class="form-wrap">
      <div class="ml-embedded" data-form="taVtu7"></div>
    </div>
  </section>
  <style>
    .sub { padding-top: 56px; max-width: 640px; }
    .sub-head { margin-bottom: 28px; }
    .sub-head h1 { font-size: 36px; margin-bottom: 6px; }
    .tagline { font-family: var(--font-serif); font-style: italic; font-size: 17px; color: var(--ink); margin-bottom: 12px; }
    .sub-head .muted { font-size: 15px; line-height: 1.6; }
    .form-wrap { margin-top: 12px; }
  </style>
</Base>
