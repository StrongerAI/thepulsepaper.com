---
import Base from '../layouts/Base.astro';
import SideNav from '../components/SideNav.astro';

const title = "Ticker | The Pulse Paper";
const description = "Live Pakistan business and economic headlines, updated throughout the day. Automated from Dawn, Business Recorder, Express Tribune, and The News.";

let feed: any[] = [];
try {
  const raw = await import('../data/ticker-feed.json');
  feed = raw.default || [];
} catch {
  feed = [];
}

function timeAgo(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

function formatTime(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ', ' +
    d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', hour12: false });
}
---
<Base title={title} description={description}>

<div class="wrap-narrow">
  <div class="ticker-hero">
    <h1>The Ticker</h1>
    <p class="muted">The headlines shaping Pakistan's economic landscape.</p>
  </div>

  {feed.length === 0 && (
    <p class="muted" style="text-align:center;padding:48px 0;">No headlines yet. The feed updates automatically.</p>
  )}

  <div class="ticker-feed">
    {feed.map((item: any) => (
      <a href={item.link} target="_blank" rel="noopener noreferrer" class="ticker-item">
        <span class="ticker-headline">{item.title}</span>
        <span class="ticker-meta">
          <span class="ticker-source">{item.source}</span>
          <span class="ticker-time">{formatTime(item.published)}</span>
        </span>
      </a>
    ))}
  </div>

  <p class="ticker-footnote muted">
    Sourced from Dawn, Business Recorder, Express Tribune, The News, BBC, Bloomberg, and WSJ. Filtered for Pakistan macro and international relevance. Not editorial — headlines as published.
  </p>
</div>

<SideNav currentPage="/ticker" />

</Base>

<style>
  .ticker-hero {
    padding: 48px 0 24px;
  }
  .ticker-hero h1 {
    font-size: 32px;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .ticker-hero .muted {
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 15px;
  }

  .ticker-feed {
    display: flex;
    flex-direction: column;
    padding-left: 24px;
    margin-left: 5px;
    position: relative;
  }
  .ticker-feed::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 0;
    width: 0;
    border-left: 1.5px dashed var(--border);
    opacity: 0.6;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 60%, rgba(0,0,0,0));
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 60%, rgba(0,0,0,0));
  }

  .ticker-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 12px 0;
    text-decoration: none;
    color: var(--ink);
    transition: color 0.15s;
    position: relative;
  }
  .ticker-item::before {
    content: '';
    position: absolute;
    left: -22px;
    top: 17px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: var(--paper);
    transition: border-color 0.2s, background 0.2s;
  }
  .ticker-item:first-child::before {
    background: var(--accent);
    border-color: var(--accent);
  }
  .ticker-item:hover::before {
    border-color: var(--accent);
    background: var(--accent);
  }
  .ticker-item:hover {
    color: var(--accent);
  }

  .ticker-headline {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.4;
    flex: 1;
  }

  .ticker-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    gap: 2px;
  }

  .ticker-source {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: var(--accent);
  }

  .ticker-time {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
  }

  .ticker-footnote {
    font-size: 11px;
    margin-top: 24px;
    padding-bottom: 32px;
  }

  :global(.side-nav) {
    right: max(calc((100vw - var(--maxw) - 320px) / 2), 16px) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  @media (max-width: 768px) {
    .ticker-hero { padding-top: 32px; }
    .ticker-hero h1 { font-size: 26px; }
    .ticker-item {
      flex-direction: column;
      gap: 4px;
    }
    .ticker-meta {
      flex-direction: row;
      align-items: baseline;
      gap: 8px;
    }
  }
</style>
