---
import Base from '../layouts/Base.astro';
import { glossary } from '../data/glossary';

const terms = Object.values(glossary).sort((a, b) => a.label.localeCompare(b.label));
---
<Base
  title="Glossary | The Pulse Paper"
  description="Plain-language definitions of the economic and market terms used in The Pulse Paper — REER, Brent, CPI, backwardation, and more, explained simply."
>
  <section class="wrap-narrow gloss">
    <header class="gloss-head">
      <h1>Glossary</h1>
      <p class="muted">Plain-language definitions of the terms we use. No jargon left unexplained.</p>
    </header>
    <dl class="gloss-list">
      {terms.map((t) => (
        <div class="gloss-item">
          <dt>{t.label}</dt>
          <dd>{t.def}</dd>
        </div>
      ))}
    </dl>
  </section>
  <style>
    .gloss { padding-top: 56px; }
    .gloss-head { margin-bottom: 32px; }
    .gloss-head h1 { font-family: var(--font-serif); font-size: 36px; margin-bottom: 8px; }
    .gloss-list { margin: 0; }
    .gloss-item { padding: 20px 0; border-bottom: 1px solid var(--border); }
    .gloss-item:first-child { border-top: 2px solid var(--ink); }
    dt { font-family: var(--font-serif); font-size: 19px; margin-bottom: 6px; }
    dd { margin: 0; font-size: 15.5px; line-height: 1.65; color: var(--muted); }
  </style>
</Base>
