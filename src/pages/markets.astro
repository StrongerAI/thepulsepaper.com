---
// src/pages/markets.astro
import Base from '../layouts/Base.astro';
import { marketsData as m } from '../data/markets.js';

const title = "Pakistan Markets | The Pulse Paper";
const description = "Pakistan market data updated throughout the trading day. KSE-100, PSX indices, Brent crude, rupee rate, global commodities, and what the numbers mean for Pakistan.";

// Region order for international exchanges
const regions = ['Americas', 'Europe', 'Asia', 'Currencies'];

// Build SVG chart data at build time (matches edition/specials aesthetic)
function computeChart(data: {date:string, value:number}[], formatY: (v:number)=>string, formatTip?: (v:number)=>string) {
  const tipFmt = formatTip || formatY;
  const viewW = 720, viewH = 220;
  const padL = 52, padR = 12, padT = 18, padB = 36;
  const plotL = padL, plotR = viewW - padR;
  const plotT = padT, plotB = viewH - padB;

  const values = data.map(d => d.value);
  const dataMin = Math.min(...values);
  const dataMax = Math.max(...values);
  const rawStep = (dataMax - dataMin) / 5;
  const mag = Math.pow(10, Math.floor(Math.log10(rawStep)));
  const res = rawStep / mag;
  const niceStep = res <= 1 ? mag : res <= 2 ? 2*mag : res <= 5 ? 5*mag : 10*mag;
  const niceMin = Math.floor(dataMin / niceStep) * niceStep;
  const niceMax = Math.ceil(dataMax / niceStep) * niceStep;

  const sy = (v:number) => plotT + (1 - (v - niceMin) / (niceMax - niceMin)) * (plotB - plotT);
  const sx = (i:number) => plotL + (i / (data.length - 1)) * (plotR - plotL);

  const pts = data.map((d, i) => ({ x: sx(i), y: sy(d.value), date: d.date, value: d.value, tip: d.date + ': ' + tipFmt(d.value) }));

  const gridLines: {y:number, label:string}[] = [];
  for (let v = niceMin; v <= niceMax + 0.001; v += niceStep) {
    gridLines.push({ y: sy(v), label: formatY(v) });
  }

  const polyline = pts.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
  const polygon = `${pts[0].x.toFixed(1)},${plotB} ${polyline} ${pts[pts.length-1].x.toFixed(1)},${plotB}`;

  const labelEvery = Math.max(1, Math.ceil(data.length / 12));
  const xLabels = pts.filter((_, i) => i % labelEvery === 0);

  return { pts, gridLines, polyline, polygon, xLabels, plotB, plotL, plotR, viewW, viewH };
}

const fmtKseAxis = (v: number) => Math.round(v/1000)+'k';
const fmtKseTip = (v: number) => v.toLocaleString('en-US');
const fmtBrentAxis = (v: number) => '$'+v.toFixed(0);
const fmtBrentTip = (v: number) => '$'+v.toFixed(2);

const kse = computeChart(m.kseHistory, fmtKseAxis, fmtKseTip);
const brent = computeChart(m.brentHistory, fmtBrentAxis, fmtBrentTip);
---
<Base title={title} description={description}>

<div class="wrap-narrow">

  <!-- ===== HERO ===== -->
  <div class="markets-hero">
    <h1>Pakistan markets today</h1>
    <p class="muted">Updated throughout the trading day. Not investment advice.</p>
    <p class="markets-updated">{m.lastUpdated}</p>
  </div>

  <!-- ===== TICKER STRIP ===== -->
  <div class="ticker-strip">
    {m.ticker.map(t => (
      <div class="ticker-cell">
        <span class="data-label">{t.name}</span>
        <span class="ticker-val">{t.value}</span>
        <span class={`data-delta delta-${t.direction === 'up' ? 'up' : t.direction === 'down' ? 'down' : 'flat'}`}>{t.changePct}</span>
      </div>
    ))}
  </div>

  <!-- ===== KSE-100 CHART ===== -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">01</span>
      <h2 class="section-title">KSE-100 trajectory</h2>
    </div>
    <p class="muted" style="margin-bottom:16px;">Weekly Friday close since 1 January 2026</p>
    <svg viewBox={`0 0 ${kse.viewW} ${kse.viewH}`} xmlns="http://www.w3.org/2000/svg" style="width:100%; height:auto; display:block;" role="img" aria-label="KSE-100 weekly trajectory since January 2026">
      {kse.gridLines.map(gl => (<g>
        <line x1={kse.plotL} y1={gl.y.toFixed(1)} x2={kse.plotR} y2={gl.y.toFixed(1)} stroke="var(--border)" stroke-width="0.5" stroke-dasharray="3,3"/>
        <text x={kse.plotL - 8} y={(gl.y + 4).toFixed(1)} text-anchor="end" font-family="'IBM Plex Mono', monospace" font-size="9" fill="var(--muted)" opacity="0.6">{gl.label}</text>
      </g>))}
      <line x1={kse.plotL} y1={kse.plotB} x2={kse.plotR} y2={kse.plotB} stroke="var(--ink)" stroke-width="1"/>
      <polygon points={kse.polygon} fill="var(--green)" fill-opacity="0.06"/>
      <polyline points={kse.polyline} fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
      {kse.pts.map(p => (<g class="chart-dot">
        <circle cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="12" fill="transparent" class="chart-hit"/>
        <circle cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="2" fill="var(--green)" class="chart-point"/>
        <g class="chart-tip" transform={`translate(${p.x.toFixed(1)},${(p.y - 14).toFixed(1)})`}>
          <rect x="-48" y="-12" width="96" height="16" rx="2" fill="var(--ink)" opacity="0.92"/>
          <text x="0" y="0" text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="8.5" font-weight="600" fill="#fff">{p.tip}</text>
        </g>
      </g>))}
      {kse.xLabels.map(p => (
        <text x={p.x.toFixed(1)} y={(kse.plotB + 18).toFixed(1)} text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="9" fill="var(--muted)">{p.date}</text>
      ))}
    </svg>
  </div>

  <!-- ===== PAKISTAN MACRO TRACKER ===== -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">02</span>
      <h2 class="section-title">Pakistan macro tracker</h2>
    </div>
    <p class="muted" style="margin-bottom:16px;">Domestic indicators that set the planning environment</p>
    <table class="mini-table">
      <thead>
        <tr><th>Indicator</th><th style="text-align:right;">Prior</th><th style="text-align:right;">Current</th><th style="text-align:right;">Change</th></tr>
      </thead>
      <tbody>
        {m.weekOverWeek.rows.filter(row =>
          ['KSE-100', 'USD / PKR', 'EUR / USD', 'Petrol (MS)', 'Gold 24K (tola)', 'Silver (tola)', 'SPI (YoY)'].includes(row.name)
        ).map(row => (
          <tr>
            <td style="font-weight:600;">{row.name}</td>
            <td style="text-align:right;">{row.prev}</td>
            <td style="text-align:right;">{row.current}</td>
            <td style={`text-align:right;`} class={`delta-${row.direction === 'up' ? 'up' : row.direction === 'down' ? 'down' : 'flat'}`}>{row.change}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="muted" style="font-size:11px;margin-top:6px;">Prior = previous session value. Current = latest available. Change = session-to-session move.</p>

    <div class="sub-heading" style="margin-top:24px;">Commodities</div>
    <table class="mini-table">
      <thead>
        <tr><th>Commodity</th><th style="text-align:right;">Prior</th><th style="text-align:right;">Current</th><th style="text-align:right;">Change</th></tr>
      </thead>
      <tbody>
        {m.weekOverWeek.rows.filter(row =>
          ['Brent crude', 'WTI crude', 'Dubai Platts', 'Gold', 'Silver', 'Natural Gas'].includes(row.name)
        ).map(row => (
          <tr>
            <td style="font-weight:600;">{row.name}</td>
            <td style="text-align:right;">{row.prev}</td>
            <td style="text-align:right;">{row.current}</td>
            <td style={`text-align:right;`} class={`delta-${row.direction === 'up' ? 'up' : row.direction === 'down' ? 'down' : 'flat'}`}>{row.change}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="section-commentary">
      <p>{m.weekOverWeek.commentary}</p>
    </div>
  </div>

  <!-- ===== PSX INDICES ===== -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">03</span>
      <h2 class="section-title">PSX indices</h2>
    </div>
    <p class="muted" style="margin-bottom:16px;">Pakistan Stock Exchange, end-of-day close</p>

    <div class="sub-heading">Headline indices</div>
    <div class="data-grid">
      {m.psx.headline.map(idx => (
        <div class={`data-card ${idx.direction === 'up' ? 'green' : idx.direction === 'down' ? 'red' : 'neutral'}`}>
          <div class="data-label">{idx.name}</div>
          <div class="data-value">{idx.value}</div>
          <div class="data-card-rule"></div>
          <div class={`data-delta delta-${idx.direction === 'up' ? 'up' : idx.direction === 'down' ? 'down' : 'flat'}`}>{idx.change}</div>
        </div>
      ))}
    </div>

    <div class="sub-heading">Sector trackers</div>
    <div class="data-grid">
      {m.psx.sector.map(idx => (
        <div class={`data-card ${idx.direction === 'up' ? 'green' : idx.direction === 'down' ? 'red' : 'neutral'}`}>
          <div class="data-label">{idx.name}</div>
          <div class="data-value">{idx.value}</div>
          <div class="data-card-rule"></div>
          <div class={`data-delta delta-${idx.direction === 'up' ? 'up' : idx.direction === 'down' ? 'down' : 'flat'}`}>{idx.change}</div>
        </div>
      ))}
    </div>

    <div class="sub-heading">Thematic and fund indices</div>
    <div class="data-grid" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));">
      {m.psx.thematic.map(idx => (
        <div class={`data-card ${idx.direction === 'up' ? 'green' : idx.direction === 'down' ? 'red' : 'neutral'}`}>
          <div class="data-label">{idx.name}</div>
          <div class="data-value" style="font-size:20px;">{idx.value}</div>
          <div class="data-card-rule"></div>
          <div class={`data-delta delta-${idx.direction === 'up' ? 'up' : idx.direction === 'down' ? 'down' : 'flat'}`}>{idx.change}</div>
        </div>
      ))}
    </div>

    <div class="section-commentary">
      <p>{m.psx.commentary}</p>
    </div>
  </div>

  <!-- ===== INTERNATIONAL COMMODITIES ===== -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">04</span>
      <h2 class="section-title">International commodities</h2>
    </div>
    <p class="muted" style="margin-bottom:16px;">Benchmark prices that flow into Pakistan's import bill</p>
    <div class="data-grid">
      {m.commodities.rows.map(c => (
        <div class="data-card neutral">
          <div class="data-label">{c.name}</div>
          <div class="data-value">{c.value} <span style="font-size:14px;font-weight:400;color:var(--muted);">{c.unit}</span></div>
          <div class="data-card-rule"></div>
          <div class="data-delta delta-flat">O {c.open} · H {c.high} · L {c.low}</div>
        </div>
      ))}
    </div>
    <p class="muted" style="font-size:12px;margin-top:8px;">{m.commodities.footnote}</p>
    <div class="section-commentary">
      <p>{m.commodities.commentary}</p>
    </div>
  </div>

  <!-- ===== INTERNATIONAL EXCHANGES ===== -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">05</span>
      <h2 class="section-title">International exchanges</h2>
    </div>
    <p class="muted" style="margin-bottom:16px;">Major global indices and currencies, grouped by region</p>

    {regions.map(region => (
      <div style="margin-bottom:20px;">
        <div class="sub-heading">{region}</div>
        <table class="mini-table">
          <thead>
            <tr>
              <th>{region === 'Currencies' ? 'Pair' : 'Index'}</th>
              <th style="text-align:right;">Close</th>
              <th style="text-align:right;">Open</th>
              <th style="text-align:right;">Day range</th>
            </tr>
          </thead>
          <tbody>
            {m.international.rows.filter(row => row.region === region).map(row => (
              <tr style={row.muted ? 'color:var(--muted);' : ''}>
                <td style="font-weight:600;">{row.name}</td>
                <td style="text-align:right;">{row.close}</td>
                <td style="text-align:right;">{row.open || '\u2014'}</td>
                <td style="text-align:right;">{row.range}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ))}

    <div class="section-commentary">
      <p>{m.international.commentary}</p>
    </div>
  </div>

  <!-- ===== BRENT CHART ===== -->
  <div class="section" style="border-bottom:none;">
    <div class="section-header">
      <span class="section-num">06</span>
      <h2 class="section-title">Brent crude since 1 January 2026</h2>
    </div>
    <p class="muted" style="margin-bottom:16px;">Tracking the war premium, week by week</p>
    <svg viewBox={`0 0 ${brent.viewW} ${brent.viewH}`} xmlns="http://www.w3.org/2000/svg" style="width:100%; height:auto; display:block;" role="img" aria-label="Brent crude weekly price since January 2026">
      {brent.gridLines.map(gl => (<g>
        <line x1={brent.plotL} y1={gl.y.toFixed(1)} x2={brent.plotR} y2={gl.y.toFixed(1)} stroke="var(--border)" stroke-width="0.5" stroke-dasharray="3,3"/>
        <text x={brent.plotL - 8} y={(gl.y + 4).toFixed(1)} text-anchor="end" font-family="'IBM Plex Mono', monospace" font-size="9" fill="var(--muted)" opacity="0.6">{gl.label}</text>
      </g>))}
      <line x1={brent.plotL} y1={brent.plotB} x2={brent.plotR} y2={brent.plotB} stroke="var(--ink)" stroke-width="1"/>
      <polygon points={brent.polygon} fill="var(--accent)" fill-opacity="0.06"/>
      <polyline points={brent.polyline} fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
      {brent.pts.map(p => (<g class="chart-dot">
        <circle cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="12" fill="transparent" class="chart-hit"/>
        <circle cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="2" fill="var(--accent)" class="chart-point"/>
        <g class="chart-tip" transform={`translate(${p.x.toFixed(1)},${(p.y - 14).toFixed(1)})`}>
          <rect x="-48" y="-12" width="96" height="16" rx="2" fill="var(--ink)" opacity="0.92"/>
          <text x="0" y="0" text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="8.5" font-weight="600" fill="#fff">{p.tip}</text>
        </g>
      </g>))}
      {brent.xLabels.map(p => (
        <text x={p.x.toFixed(1)} y={(brent.plotB + 18).toFixed(1)} text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="9" fill="var(--muted)">{p.date}</text>
      ))}
    </svg>
  </div>

  <!-- ===== EDITION CALLOUT ===== -->
  <div class="callout" style="margin:32px 0;border-left-color:var(--accent);">
    <strong>From the latest edition</strong>
    Edition {m.latestEdition.number}: "{m.latestEdition.title}." {m.latestEdition.summary}
    <a href={m.latestEdition.url} style="display:inline-block;margin-top:10px;color:var(--accent);font-weight:600;text-decoration:underline;text-underline-offset:3px;">Read Edition {m.latestEdition.number} &rarr;</a>
  </div>

</div>


</Base>

<style>
  /* ===== Markets-specific styles (everything else inherits from theme.css) ===== */

  .markets-hero {
    text-align: center;
    padding: 48px 0 8px;
  }
  .markets-hero h1 {
    font-size: 32px;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .markets-hero .muted {
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 15px;
  }
  .markets-updated {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.5px;
    margin-top: 12px;
  }

  /* ===== TICKER STRIP ===== */
  .ticker-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
    margin: 28px 0 8px;
  }
  .ticker-cell {
    background: var(--card-bg);
    padding: 14px 16px 12px;
    border: 1px solid #d3c6b6;
    border-left: 4px solid #b8a896;
    display: flex;
    flex-direction: column;
  }
  .ticker-cell .data-label {
    margin-bottom: 6px;
  }
  .ticker-val {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 8px;
  }
  .ticker-cell .data-delta {
    font-family: 'Crimson Pro', serif;
    font-size: 13px;
    font-style: italic;
    margin-top: auto;
    border-top: 1px solid #e0d4c8;
    padding-top: 6px;
  }

  /* ===== DATA RANGE (high/low on cards) ===== */
  .data-range {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    margin-top: 4px;
    letter-spacing: 0.3px;
  }

  /* ===== CHART (inline SVG) ===== */
  .section svg[role="img"] {
    margin-top: 4px;
  }
  .chart-tip { opacity: 0; pointer-events: none; transition: opacity 0.15s ease; }
  .chart-point { transition: r 0.15s ease; }
  .chart-hit { cursor: pointer; }
  .chart-dot:hover .chart-tip { opacity: 1; }
  .chart-dot:hover .chart-point { r: 4; }

  /* ===== SECTION COMMENTARY (the editorial paragraph under each section's data) ===== */
  .section-commentary {
    margin-top: 20px;
    padding: 16px 18px;
    background: var(--card-bg);
    border-left: 3px solid var(--accent);
  }
  .section-commentary p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .markets-hero { padding-top: 32px; }
    .markets-hero h1 { font-size: 26px; }
    .ticker-strip { grid-template-columns: repeat(3, 1fr); }
    .ticker-val { font-size: 18px; }
    .section svg[role="img"] { margin-top: 2px; }
    .section-commentary { padding: 14px 14px; }
    .section-commentary p { font-size: 14px; }
    .mini-table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  }
</style>
